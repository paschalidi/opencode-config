{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/kimi-k2.6",
  "instructions": [
    "~/.config/opencode/instructions/logging-standards.md",
    "~/.config/opencode/instructions/python-testing-standards.md",
    "~/.config/opencode/instructions/cover-letter.md"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": true,
      "environment": {
        "BROWSER": "${BROWSER:-chromium}"
      }
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GH_PERSONAL_TOKEN}"
      }
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    },
    "jira": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-atlassian"
      ],
      "enabled": true,
      "environment": {
        "JIRA_URL": "https://numan.atlassian.net",
        "JIRA_USERNAME": "christos.paschalidis@numan.com",
        "JIRA_API_TOKEN": "${JIRA_PERSONAL_TOKEN}"
      }
    },
    "mcp-obsidian": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "/Users/christos/dev/mcp-obsidian",
        "run",
        "mcp-obsidian"
      ],
      "enabled": true,
      "environment": {
        "OBSIDIAN_API_KEY": "81521bc93070b19c3e7b716d2f661a6fb475e09f6b59cc448705f2c670fdabd1",
        "OBSIDIAN_HOST": "127.0.0.1",
        "OBSIDIAN_PORT": "27124"
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow"
  }
}
