{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": true,
      "environment": {
        "BROWSER": "${BROWSER:-chromium}"
      }
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GH_PERSONAL_TOKEN}"
      }
    },
    "brave-search": {
      "type": "remote",
      "url": "https://api.search.brave.com/res/v1/web/search",
      "enabled": false,
      "headers": {
        "X-Subscription-Token": "${BRAVE_API_KEY}"
      }
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    },
    "jira": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-atlassian"
      ],
      "enabled": true,
      "environment": {
        "JIRA_URL": "https://numan.atlassian.net",
        "JIRA_USERNAME": "christos.paschalidis@numan.com",
        "JIRA_API_TOKEN": "${JIRA_PERSONAL_TOKEN}"
      }
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/christos/dev/numan/numan-development/repos/the-monolith"
      ],
      "enabled": true
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow"
  }
}
