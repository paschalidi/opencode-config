# Environment variables for OpenCode MCP configuration
# Copy this file to .env and fill in your actual secrets
# NEVER commit .env to git!

# Browser for Playwright MCP (optional, defaults to chromium)
# BROWSER=chromium

# GitHub MCP server URL (if using a remote GitHub MCP)
# GITHUB_MCP_URL=https://your-github-mcp-server.example.com/sse

# GitHub personal access token
# GITHUB_TOKEN=ghp_your_token_here

# Brave Search API key (optional)
# BRAVE_API_KEY=your_brave_api_key_here

# Add other MCP server secrets below as needed
