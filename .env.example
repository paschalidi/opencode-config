# Environment variables for OpenCode MCP configuration
# Copy this file to .env and fill in your actual secrets
# NEVER commit .env to git!

# Browser for Playwright MCP (optional, defaults to chromium)
# BROWSER=chromium

# GitHub personal access token (for @modelcontextprotocol/server-github)
GH_PERSONAL_TOKEN=ghp_your_github_token_here

# Brave Search API key (optional)
# BRAVE_API_KEY=your_brave_api_key_here

# Jira personal token
JIRA_PERSONAL_TOKEN=your_jira_api_token_here
